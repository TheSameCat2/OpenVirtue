# Normalize line endings: LF in the repo, native on checkout.
* text=auto

# C# / project files
*.cs       text diff=csharp
*.csproj   text
*.sln      text eol=crlf
*.props    text
*.targets  text

# Scripts
*.ps1      text eol=crlf
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.sh       text eol=lf

# Docs
*.md       text
*.json     text
*.yml      text
*.yaml     text

# Treat known binaries as binary (defensive — these should be gitignored anyway)
*.wrs      binary
*.wmp      binary
*.mdl      binary
*.wad      binary
*.pcx      binary
*.png      binary
*.exe      binary
*.dll      binary
